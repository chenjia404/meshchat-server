APP_NAME=meshchat-server
LOG_LEVEL=info
HTTP_ADDR=:8080
ADMIN_HTTP_ADDR=:8081
SHUTDOWN_TIMEOUT=10s
SERVER_MODE=restricted
SERVER_ADMIN_PEER_IDS=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
DATABASE_URL=postgres://meshchat:meshchat@localhost:5432/meshchat?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=change-me-in-production
JWT_ISSUER=meshchat-server
JWT_EXPIRATION=72h
AUTH_CHALLENGE_TTL=5m
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_UPSTREAM=
IPFS_GATEWAY_BASE_URL=
AUTO_MIGRATE=true
LEGACY_API_ROOT=true
WS_WRITE_WAIT=10s
WS_PONG_WAIT=60s
WS_PING_INTERVAL=54s
WS_SEND_BUFFER=128
ONLINE_TTL=90s
